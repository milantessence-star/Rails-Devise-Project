<style>
        /* General Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            line-height: 1.6;
            color: #333;
            background-color: #f4f7f6;
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 5%;
            background: #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: #2c3e50;
        }

        .nav-links {
            list-style: none;
            display: flex;
        }

        .nav-links li {
            margin-left: 20px;
        }

        .nav-links a {
            text-decoration: none;
            color: #333;
            font-weight: 500;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: #3498db;
        }

        /* Hero Section */
        .hero {
            height: 80vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), 
                        url('https://images.unsplash.com/photo-1497215728101-856f4ea42174?auto=format&fit=crop&w=1350&q=80');
            background-size: cover;
            background-position: center;
            color: white;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            max-width: 600px;
        }

        .btn {
            display: inline-block;
            background: #3498db;
            color: #fff;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 5px;
            transition: background 0.3s;
        }

        .btn:hover {
            background: #2980b9;
        }

        /* Features Section */
        .features {
            display: flex;
            justify-content: space-around;
            padding: 4rem 5%;
            background: #fff;
            flex-wrap: wrap;
        }

        .feature-card {
            flex: 1;
            min-width: 250px;
            margin: 10px;
            padding: 20px;
            text-align: center;
            border-radius: 8px;
            background: #f9f9f9;
            transition: transform 0.3s;
        }

        .feature-card:hover {
            transform: translateY(-10px);
        }

        .feature-card i {
            font-size: 2rem;
            color: #3498db;
            margin-bottom: 10px;
        }

        /* Footer */
        footer {
            background: #2c3e50;
            color: white;
            text-align: center;
            padding: 2rem 0;
            margin-top: 20px;
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .nav-links {
                display: none; /* Simplification for this example */
            }
            .hero h1 {
                font-size: 2rem;
            }
        }
    </style>
    <nav>
        <div class="logo">BRANDNAME</div>
        <ul class="nav-links">
            <li><a href="#">Home</a></li>
            <li><a href="#">Services</a></li>
            <li><a href="#">Portfolio</a></li>
            <li><a href="#">Contact</a></li>
        </ul>
    </nav>

    <header class="hero">
        <h1>Welcome to Your Future</h1>
        <p>We provide innovative solutions to help your business grow in the digital age. Clean design meets powerful performance.</p>
        <%= link_to "Get Started Today", new_user_session_path, class: "btn" %>
    </header>

    <section class="features">
        <div class="feature-card">
            <h3>Responsive Design</h3>
            <p>Your site will look great on any device, from mobile phones to desktop monitors.</p>
        </div>
        <div class="feature-card">
            <h3>Fast Performance</h3>
            <p>Optimized code ensures your users aren't left waiting for pages to load.</p>
        </div>
        <div class="feature-card">
            <h3>Secure Hosting</h3>
            <p>We prioritize the safety of your data with industry-leading security protocols.</p>
        </div>
    </section>

    <footer>
        <p>&copy; 2026 BrandName. All rights reserved.</p>
    </footer>